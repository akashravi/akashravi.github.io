root = true

[*]
charset = utf-8
end_of_line = lf
insert_final_newline = true
trim_trailing_whitespace = true
indent_style = space
indent_size = 2

[*.md]
trim_trailing_whitespace = false

[*.{ico,png,jpg,jpeg,gif,webp,avif,woff,woff2,eot,ttf,otf}]
charset = unset
trim_trailing_whitespace = unset
insert_final_newline = unset
