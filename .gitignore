# .gitignore

# Dependencies
node_modules/

# Jekyll build output
_site/
.jekyll-cache/
.jekyll-metadata

# Ruby / Bundler (CI installs gems here via bundler-cache)
vendor/

# Resolved per-environment (Windows local vs. Linux CI) to avoid native-gem platform locks
Gemfile.lock

# Build outputs
dist/
build/

# OS files
.DS_Store
Thumbs.db

# Editor directories
.vscode/
.idea/
*.sublime-project
*.sublime-workspace

# Logs
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*

# Environment variables
.env
.env.local
.env.*.local

# Testing
coverage/
.nyc_output/

# Temporary files
*.tmp
*.temp
.cache/
